{
    "//": "Template tsconfig for Office Scripts projects. Users can copy this into their scripts folder, or the VS Code extension's TS Server Plugin injects equivalent types automatically.",
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "strict": true,
        "noImplicitAny": true,
        "noEmit": true,
        "types": [],
        "allowJs": false,
        "moduleResolution": "Node",
        "skipLibCheck": true
    },
    "include": [
        "./types/excel-script.d.ts",
        "**/*.osts",
        "**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
