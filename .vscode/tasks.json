{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "watch",
            "dependsOn": [
                "npm: watch:esbuild",
                "npm: watch:tsc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "type": "npm",
            "script": "watch:esbuild",
            "label": "npm: watch:esbuild",
            "problemMatcher": "$esbuild-watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never",
                "group": "watch"
            }
        },
        {
            "type": "npm",
            "script": "watch:tsc",
            "label": "npm: watch:tsc",
            "problemMatcher": "$tsc-watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never",
                "group": "watch"
            }
        }
    ]
}
